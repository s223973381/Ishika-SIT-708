<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mint"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/homeCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Greeting -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Hello,\nStudent"
            android:textColor="@color/text_dark"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTaskDue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="You have 1 task due"
            android:textColor="@color/coral"
            android:textSize="15sp" />

        <!-- Task Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generated by AI"
                android:textColor="@color/coral_dark"
                android:textSize="12sp"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Generated Task 1"
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTaskDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Binary Search Algorithm — A fundamental divide-and-conquer search technique."
                android:textColor="@color/text_medium"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnStartQuiz"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="@color/coral"
                android:contentDescription="Start quiz button"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="Start Quiz"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Learning Tools header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Learning Tools"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etCustomPrompt"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/edit_text_bg"
            android:contentDescription="Type your own question or leave blank for default"
            android:hint="Ask anything… (optional)"
            android:inputType="textMultiLine"
            android:maxLines="2"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_hint"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGenerateHint"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/coral"
                android:contentDescription="Generate a hint for the current question"
                android:text="Generate Hint"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnExplainAnswer"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/salmon"
                android:contentDescription="Explain why the answer is correct or incorrect"
                android:text="Explain Answer"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Prompt display -->
        <TextView
            android:id="@+id/tvPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:text=""
            android:textColor="@color/text_medium"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Loading state -->
        <TextView
            android:id="@+id/tvLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="Loading..."
            android:textColor="@color/loading_grey"
            android:textSize="16sp"
            android:textStyle="italic"
            android:visibility="gone" />

        <!-- LLM Response -->
        <TextView
            android:id="@+id/tvResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/cream_card_bg"
            android:padding="16dp"
            android:text=""
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:visibility="gone" />

        <!-- Error state -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text=""
            android:textColor="@color/error_red"
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
