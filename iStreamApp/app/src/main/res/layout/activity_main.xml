<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#E53935"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="iStream"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFF"/>

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFF"
            android:textSize="13sp"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Logout"
            android:textSize="11sp"
            android:backgroundTint="#C62828"
            android:textColor="#FFF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"/>
    </LinearLayout>

    <!-- WebView player -->
    <WebView
        android:id="@+id/webViewPlayer"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#000"/>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YouTube Video URL"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etVideoUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Paste YouTube link here"
            android:saveEnabled="false"
            android:inputType="textUri"
            android:background="@drawable/rounded_input"
            android:padding="14dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvUrlError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E53935"
            android:text=""
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶  PLAY"
            android:backgroundTint="#E53935"
            android:textColor="#FFF"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnAddToPlaylist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="＋  ADD TO PLAYLIST"
            android:backgroundTint="#1565C0"
            android:textColor="#FFF"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnMyPlaylist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="☰  MY PLAYLIST"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFF"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnOpenInYoutube"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="↗  OPEN IN YOUTUBE APP"
            android:backgroundTint="#FF6D00"
            android:textColor="#FFF"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>