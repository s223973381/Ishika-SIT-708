<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Voyage logo emblem (launcher icon variant — no text, emblem only).
        Colours:  burgundy=#7B1535  gold=#C4A265  tan=#D4BB8A  cream=#EAD8B8
        Circle: center(54,50) radius 32. Arc leaves gap at upper-right for the airplane exit.
    -->

    <!-- ── Maroon ground / landscape fill (bottom of circle) ── -->
    <path
        android:fillColor="#7B1535"
        android:pathData="M 24,66 Q 39,60 54,64 Q 70,68 84,64 Q 86,74 78,80 Q 68,85 54,85 Q 40,85 30,80 Q 22,74 24,66 Z" />

    <!-- ── Mountains – background peak (tan) ── -->
    <path
        android:fillColor="#D4BB8A"
        android:pathData="M 57,67 L 69,48 L 81,67 Z" />

    <!-- ── Mountains – foreground peak (darker gold) ── -->
    <path
        android:fillColor="#C4A265"
        android:pathData="M 65,67 L 77,42 L 89,67 Z" />

    <!-- ── Snow highlight on foreground peak ── -->
    <path
        android:fillColor="#EAD8B8"
        android:pathData="M 77,42 L 72,52 L 82,52 Z" />

    <!-- ── Winding road through landscape ── -->
    <path
        android:strokeColor="#D4BB8A"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M 35,81 Q 46,72 54,69 Q 63,71 71,77" />

    <!-- ── Location pin body (cream teardrop) ── -->
    <path
        android:fillColor="#EAD8B8"
        android:pathData="M 73,64 C 77.5,64 81,67.5 81,72 C 81,76.5 73,84 73,84 C 73,84 65,76.5 65,72 C 65,67.5 68.5,64 73,64 Z" />

    <!-- ── Location pin inner dot (maroon) ── -->
    <path
        android:fillColor="#7B1535"
        android:pathData="M 73,68.5 A 2.8,2.8 0 1 0 73.001,68.5 Z" />

    <!-- ── Partial circle arc – gap at upper-right where airplane exits ──
         Arc from ~72° (64,18) counterclockwise to ~28° (82,35), covering ~316° of circle -->
    <path
        android:strokeColor="#7B1535"
        android:strokeWidth="2.6"
        android:fillColor="@android:color/transparent"
        android:pathData="M 64,18 A 32,32 0 1 0 82,35" />

    <!-- ── Airplane trail / swoosh (curved stroke, right arm of V → airplane) ── -->
    <path
        android:strokeColor="#7B1535"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M 67,55 Q 77,38 83,27" />

    <!-- ── 4-pointed compass star (gold) – upper left of circle ── -->
    <path
        android:fillColor="#C4A265"
        android:pathData="M 38,27 L 40.5,33 L 46,36 L 40.5,39 L 38,45 L 35.5,39 L 30,36 L 35.5,33 Z" />

    <!-- ── V letterform – left arm (maroon triangle) ── -->
    <path
        android:fillColor="#7B1535"
        android:pathData="M 21,22 L 33,22 L 54,77 Z" />

    <!-- ── V letterform – right arm (maroon triangle) ── -->
    <path
        android:fillColor="#7B1535"
        android:pathData="M 75,22 L 87,22 L 54,77 Z" />

    <!-- ── Serif caps on V (small horizontal brackets at tops of each arm) ── -->
    <path
        android:fillColor="#7B1535"
        android:pathData="M 17,22 L 37,22 L 37,25 L 17,25 Z" />
    <path
        android:fillColor="#7B1535"
        android:pathData="M 71,22 L 91,22 L 91,25 L 71,25 Z" />

    <!-- ── Airplane silhouette (pointing upper-right) ── -->
    <!-- Body -->
    <path
        android:fillColor="#7B1535"
        android:pathData="M 84,22 L 89,26 L 84,31 L 80,28 Z" />
    <!-- Forward wing -->
    <path
        android:fillColor="#7B1535"
        android:pathData="M 82,26 L 76,21 L 80,27 Z" />
    <!-- Tail fin -->
    <path
        android:fillColor="#7B1535"
        android:pathData="M 84,30 L 89,33 L 84,32 Z" />

</vector>
