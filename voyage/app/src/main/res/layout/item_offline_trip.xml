<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/voyage_warm_white"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!-- Map icon badge -->
        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:text="🗺"
            android:textSize="20sp" />

        <!-- Trip info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTripTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Trip Name"
                android:textColor="@color/voyage_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTripDestination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Destination"
                android:textColor="@color/voyage_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvDownloadedAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Downloaded"
                android:textColor="@color/voyage_text_hint"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Offline badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:background="@drawable/bg_chip_selected"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:text="✓ Offline"
            android:textColor="@color/white"
            android:textSize="11sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
