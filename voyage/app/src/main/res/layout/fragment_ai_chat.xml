<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/voyage_cream"
    android:orientation="vertical">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your AI Travel Companion"
                android:textColor="@color/voyage_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Voyage AI"
                android:textColor="@color/voyage_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Mode selector chip -->
        <LinearLayout
            android:id="@+id/btnModeSelector"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_chip"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tvModeIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvModeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="Auto"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="▾"
                android:textColor="@color/voyage_text_hint"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Settings button -->
        <TextView
            android:id="@+id/btnAiSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="⚙️"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- 24-hour history note -->
    <TextView
        android:id="@+id/tvHistoryNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/voyage_cream"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="5dp"
        android:text="⏱ Chat history is kept for 24 hours"
        android:textColor="@color/voyage_text_hint"
        android:textSize="11sp" />

    <!-- ── MESSAGES ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp" />

    <!-- Typing indicator -->
    <LinearLayout
        android:id="@+id/typingIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="32dp"
            android:layout_height="32dp"
            app:cardBackgroundColor="@color/voyage_olive_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🤖"
                android:textSize="14sp" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voyage AI is thinking…"
                android:textColor="@color/voyage_text_secondary"
                android:textSize="13sp" />

            <ProgressBar
                android:layout_width="80dp"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:indeterminate="true"
                android:progressTint="@color/voyage_olive_dark" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── QUICK PROMPTS ── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/voyage_warm_white"
        android:paddingVertical="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/chipPlanDay"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="🗓️ Plan my day"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipPacking"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="🎒 Packing list"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipBudget"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="💰 Budget tips"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipCheapFood"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="🍜 Cheap food nearby"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipTranslate"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="🌐 Translate phrase"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── INPUT ROW ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/voyage_warm_white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="16dp"
        android:paddingTop="8dp">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_edit_text"
            android:hint="Type a message…"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="3"
            android:paddingHorizontal="14dp"
            android:textColor="@color/voyage_text_primary"
            android:textColorHint="@color/voyage_text_hint"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_button_crimson"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
