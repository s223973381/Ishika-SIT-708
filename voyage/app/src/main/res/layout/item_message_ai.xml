<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingVertical="4dp">

    <!-- Robot avatar -->
    <androidx.cardview.widget.CardView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        app:cardBackgroundColor="@color/voyage_olive_dark"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🤖"
            android:textSize="14sp" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="64dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bubble_ai"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/tvAiMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI response"
                android:textColor="@color/voyage_text_primary"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginStart="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAiModeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Offline"
                android:textColor="@color/voyage_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvAiTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="12:00"
                android:textColor="@color/voyage_text_hint"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
