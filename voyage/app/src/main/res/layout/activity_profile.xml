<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/voyage_cream"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_gradient"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="←"
                    android:textColor="@color/voyage_text_primary"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Profile"
                    android:textColor="@color/voyage_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnSave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button_crimson"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="10dp"
                    android:text="Save"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Avatar + name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardBackgroundColor="@color/voyage_crimson"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="4dp">

                    <TextView
                        android:id="@+id/tvAvatarInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="T"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Traveller"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="user@email.com"
                        android:textColor="@color/voyage_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── NAME SECTION ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="YOUR NAME"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="@color/voyage_warm_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@null"
                android:hint="Enter your name"
                android:inputType="textPersonName|textCapWords"
                android:paddingHorizontal="16dp"
                android:textColor="@color/voyage_text_primary"
                android:textColorHint="@color/voyage_text_hint"
                android:textSize="15sp" />
        </androidx.cardview.widget.CardView>

        <!-- ── AI MODE SECTION ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="AI MODE"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="@color/voyage_warm_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Choose how the AI assistant works"
                    android:textColor="@color/voyage_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipAiAuto"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_selected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="🤖 Auto"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/chipAiOffline"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginHorizontal="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="📴 Offline"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/chipAiOnline"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="🌐 Online"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── TRAVEL STYLE SECTION ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="TRAVEL STYLE"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="@color/voyage_warm_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Select all that apply"
                    android:textColor="@color/voyage_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipBudget"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="💸 Budget"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/chipNature"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginHorizontal="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="🌿 Nature"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/chipAdventure"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="🧗 Adventure"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipCulture"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="🏛️ Culture"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/chipLuxury"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginHorizontal="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="💎 Luxury"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/chipFood"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="🍜 Food"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── PREFERENCES SECTION ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="ACCOUNT"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="@color/voyage_warm_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/rowPreferences"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:text="⚙️"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="Preferences"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/voyage_text_hint"
                        android:textSize="22sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="66dp"
                    android:background="@color/voyage_divider" />

                <LinearLayout
                    android:id="@+id/rowPermissions"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:text="🔐"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="Permissions"
                        android:textColor="@color/voyage_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/voyage_text_hint"
                        android:textSize="22sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="66dp"
                    android:background="@color/voyage_divider" />

                <LinearLayout
                    android:id="@+id/rowLogout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:text="🚪"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="Logout"
                        android:textColor="@color/voyage_crimson"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
