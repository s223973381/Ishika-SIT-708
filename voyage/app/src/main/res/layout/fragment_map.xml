<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-screen OSM map -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Top overlay: search bar + filter chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingTop="8dp">

        <!-- Back button + Search bar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Back button -->
            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="10dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/white">

                <ImageButton
                    android:id="@+id/btnMapBack"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:contentDescription="Back"
                    android:src="@drawable/ic_arrow_back"
                    android:scaleType="center" />

            </androidx.cardview.widget.CardView>

            <!-- Search bar -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍"
                        android:textSize="17sp" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Search loaded places..."
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="@color/voyage_text_primary"
                        android:textColorHint="@color/voyage_text_hint"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Filter chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="10dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="2dp">

                <TextView
                    android:id="@+id/chipFood"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="🍽 Food"
                    android:textColor="@color/voyage_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipHotels"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="🏨 Hotels"
                    android:textColor="@color/voyage_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipAttractions"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="⭐ Sights"
                    android:textColor="@color/voyage_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipTransport"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="🚌 Transit"
                    android:textColor="@color/voyage_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipEmergency"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="🚨 Emergency"
                    android:textColor="@color/voyage_text_primary"
                    android:textSize="13sp" />

            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>

    <!-- Zoom controls + download (right-center) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="12dp"
        android:orientation="vertical">

        <!-- Download area for offline -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnDownloadArea"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="21dp"
            app:cardElevation="5dp"
            app:cardBackgroundColor="@color/white">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="⬇"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/voyage_crimson" />

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardCornerRadius="21dp"
            app:cardElevation="5dp"
            app:cardBackgroundColor="@color/white">

            <TextView
                android:id="@+id/btnZoomIn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/voyage_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="21dp"
            app:cardElevation="5dp"
            app:cardBackgroundColor="@color/white">

            <TextView
                android:id="@+id/btnZoomOut"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/voyage_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Bottom panel: suggestion + nearby place cards -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_map_bottom_sheet"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingTop="14dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tvMapSuggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:text="Explore Around You"
            android:textColor="@color/voyage_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNearbyPlaces"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvMapStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp"
            android:text="Tap a filter to find places nearby"
            android:textColor="@color/voyage_text_hint"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>
