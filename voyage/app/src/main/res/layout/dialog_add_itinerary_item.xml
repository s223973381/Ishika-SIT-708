<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Day number -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="DAY NUMBER"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/etDayNumber"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_text"
            android:hint="e.g. 1"
            android:inputType="number"
            android:paddingHorizontal="14dp"
            android:textColor="@color/voyage_text_primary"
            android:textColorHint="@color/voyage_text_hint"
            android:textSize="14sp" />

        <!-- Time slot -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="TIME OF DAY"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/slotMorning"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_selected"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="🌅 Morning"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/slotAfternoon"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="3dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="☀️ Afternoon"
                android:textColor="@color/voyage_text_primary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/slotEvening"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="🌙 Evening"
                android:textColor="@color/voyage_text_primary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="ACTIVITY"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/etActivityTitle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_text"
            android:hint="e.g. Visit the museum"
            android:inputType="textCapSentences"
            android:paddingHorizontal="14dp"
            android:textColor="@color/voyage_text_primary"
            android:textColorHint="@color/voyage_text_hint"
            android:textSize="14sp" />

        <!-- Location -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="LOCATION (OPTIONAL)"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/etLocation"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_text"
            android:hint="e.g. City Centre"
            android:inputType="textCapWords"
            android:paddingHorizontal="14dp"
            android:textColor="@color/voyage_text_primary"
            android:textColorHint="@color/voyage_text_hint"
            android:textSize="14sp" />

        <!-- Estimated cost -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="ESTIMATED COST (AUD)"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/etEstimatedCost"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_text"
            android:hint="$ 0.00"
            android:inputType="numberDecimal"
            android:paddingHorizontal="14dp"
            android:textColor="@color/voyage_text_primary"
            android:textColorHint="@color/voyage_text_hint"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
