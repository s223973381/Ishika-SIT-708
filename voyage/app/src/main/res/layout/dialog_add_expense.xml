<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Category chips -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="CATEGORY"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/catFood"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_selected"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="🍔"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/catTransport"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="🚌"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/catHotel"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="🏨"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/catActivity"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="🎭"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/catOther"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="📦"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="DESCRIPTION"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/etExpenseTitle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_text"
            android:hint="e.g. Lunch at café"
            android:inputType="textCapSentences"
            android:paddingHorizontal="14dp"
            android:textColor="@color/voyage_text_primary"
            android:textColorHint="@color/voyage_text_hint"
            android:textSize="14sp" />

        <!-- Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="AMOUNT (AUD)"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_text"
            android:hint="$ 0.00"
            android:inputType="numberDecimal"
            android:paddingHorizontal="14dp"
            android:textColor="@color/voyage_text_primary"
            android:textColorHint="@color/voyage_text_hint"
            android:textSize="14sp" />

        <!-- Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="DATE"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <LinearLayout
            android:id="@+id/btnPickDate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_text"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvExpenseDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Select date"
                android:textColor="@color/voyage_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Note -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="NOTE (OPTIONAL)"
            android:textColor="@color/voyage_text_hint"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/etNote"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/bg_edit_text"
            android:gravity="top|start"
            android:hint="Any extra details…"
            android:inputType="textMultiLine|textCapSentences"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="@color/voyage_text_primary"
            android:textColorHint="@color/voyage_text_hint"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
