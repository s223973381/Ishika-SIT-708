<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/voyage_cream"
    android:orientation="vertical">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/voyage_text_primary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/tvListTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="My Packing List"
                android:textColor="@color/voyage_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnDeleteList"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="🗑️"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Progress row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/progressItems"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/voyage_crimson"
                android:progressBackgroundTint="#40FFFFFF" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="0 / 0"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── QUICK ADD ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"
        android:text="QUICK ADD"
        android:textColor="@color/voyage_text_hint"
        android:textSize="11sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/chipDocuments"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="📄 Documents"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipClothes"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="👕 Clothes"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipToiletries"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="🪥 Toiletries"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipElectronics"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="🔌 Electronics"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipMedications"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="💊 Medications"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipMisc"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="🎒 Misc"
                android:textColor="@color/voyage_text_primary"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── ITEMS LIST ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvItems"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="8dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false" />

        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Nothing packed yet"
                android:textColor="@color/voyage_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Tap a category above or + to add items"
                android:textColor="@color/voyage_text_hint"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            android:contentDescription="Add item"
            app:backgroundTint="@color/voyage_crimson"
            app:srcCompat="@android:drawable/ic_input_add"
            app:tint="#FFFFFF" />
    </FrameLayout>

</LinearLayout>
