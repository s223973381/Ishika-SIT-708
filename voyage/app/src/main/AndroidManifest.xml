<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Voyage"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <!-- Splash -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Voyage.Splash"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding -->
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false"
            android:noHistory="true" />

        <!-- Auth -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:noHistory="true"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main (bottom nav host) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Trips -->
        <activity
            android:name=".ui.trips.CreateTripActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.trips.TripDetailActivity"
            android:exported="false" />

        <!-- More sub-screens -->
        <activity
            android:name=".ui.more.EmergencyActivity"
            android:exported="false" />

        <activity
            android:name=".ui.more.ProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.more.GlobalBudgetActivity"
            android:exported="false" />

        <activity
            android:name=".ui.more.GlobalJournalActivity"
            android:exported="false" />

    </application>

</manifest>
