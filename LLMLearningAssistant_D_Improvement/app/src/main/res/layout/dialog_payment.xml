<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Plan summary -->
    <TextView
        android:id="@+id/tvPayPlanName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Starter Plan"
        android:textColor="@color/text_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPayPlanPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="$4.99 / month"
        android:textColor="@color/coral_dark"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="@color/peach" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose payment method"
        android:textColor="@color/text_medium"
        android:textSize="13sp" />

    <!-- Google Pay button -->
    <Button
        android:id="@+id/btnPayGooglePay"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="#000000"
        android:text="  Google Pay"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- Credit / Debit Card button -->
    <Button
        android:id="@+id/btnPayCard"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/coral"
        android:text="Credit / Debit Card"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- Cancel -->
    <TextView
        android:id="@+id/tvPayCancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:padding="8dp"
        android:text="Cancel"
        android:textColor="@color/text_medium"
        android:textSize="14sp" />

</LinearLayout>
